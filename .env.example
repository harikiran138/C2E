# DATABASE
# Obtain this from your Cloud Provider (Supabase/AWS)
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# AUTHENTICATION
# Generate these using `openssl rand -hex 32` or similar
JWT_SECRET=super-secure-jwt-secret-at-least-32-chars-long
REFRESH_TOKEN_SECRET=another-super-secure-secret-for-refresh-tokens

# AUTH FALLBACKS (Remove in Production if not needed, but code requires them)
# The code strictly requires JWT_SECRET and REFRESH_TOKEN_SECRET

# SUPABASE 
NEXT_PUBLIC_SUPABASE_URL=https://ncofwpuabtxddvdjljgj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NODE_ENV
# Set to 'production' on your deployment server
NODE_ENV=development
